---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date?: Date;
}

const { title, date } = Astro.props;
---
<BaseLayout title={title}>
  <article>
    <h1>{title}</h1>
    {date && <time datetime={date.toISOString()}>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
    <slot />
  </article>
</BaseLayout>
