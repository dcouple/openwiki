# --- required ---
SSH_PUBLIC_KEY="ssh-ed25519 AAAA... your-email@example.com"
TIMEZONE=America/Los_Angeles

# --- Claude Code auth (pick one path) ---
# A) Recommended if you have Claude Pro/Max: leave ANTHROPIC_API_KEY empty.
#    Run `/login` inside `claude` once after first boot; the credential
#    persists in the autoblog_claude volume across restarts and rebuilds.
# B) If you'd rather pay per-token via the API: set ANTHROPIC_API_KEY to a
#    key from console.anthropic.com. Takes precedence over a subscription
#    login, so leave it empty if you want path A.
ANTHROPIC_API_KEY=

# --- Phase 1 defaults (laptop sandbox). Leave as-is for local dev. ---
DOMAIN=localhost
SSH_BIND=127.0.0.1      # loopback only — reachable from the laptop itself
DEV_BIND=127.0.0.1      # ALWAYS loopback — never public; Phase 2 reaches dev via SSH -L
CADDY_BIND=127.0.0.1
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# --- Phase 2 overrides (see tmp/ready-plans/phase-2-vps.md) ---
# DOMAIN=your-real-domain.com
# SSH_BIND=0.0.0.0
# CADDY_BIND=0.0.0.0
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
